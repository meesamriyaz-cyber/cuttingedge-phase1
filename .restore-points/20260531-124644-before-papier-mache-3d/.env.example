PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://<username>:<password>@<host-00>:27017,<host-01>:27017,<host-02>:27017/<database-name>?ssl=true&replicaSet=<replica-set>&authSource=admin&retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
BODY_LIMIT=1mb
LOG_FORMAT=dev
TRUST_PROXY=0
LOGIN_RATE_WINDOW_MS=900000
LOGIN_RATE_MAX=10
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@kashmirarts.com
ADMIN_PASSWORD=replace-with-one-time-admin-password
